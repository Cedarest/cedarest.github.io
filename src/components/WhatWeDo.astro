---
interface Props {
  locale?: 'en' | 'zh';
}

const { locale = 'en' } = Astro.props;

import { siteContent } from '../content/en';
import { siteContent as zhContent } from '../content/zh';
const t = locale === 'zh' ? zhContent : siteContent;
---

<section id="whatwedo" class="bg-[var(--color-bg)] min-h-screen py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section Header -->
    <div class="max-w-xl mb-16">
      <p class="text-sm font-medium text-[var(--color-primary)] tracking-wide uppercase">
        {t.whatWeDo.label}
      </p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-[var(--color-text)] leading-tight">
        {t.whatWeDo.title}
      </h2>
      <p class="mt-4 text-base text-[var(--color-text-muted)] leading-relaxed">
        {t.whatWeDo.subtitle}
      </p>
    </div>

    <!-- Three Pillars -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      <!-- Pillar 1: Sustainable Strategy -->
      <div class="flex flex-col items-start">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-[var(--color-primary-light)] mb-5">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10Z" />
            <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[var(--color-text)] mb-2">
          {t.whatWeDo.pillars[0].title}
        </h3>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
          {t.whatWeDo.pillars[0].desc}
        </p>
      </div>

      <!-- Pillar 2: Innovative Solutions -->
      <div class="flex flex-col items-start">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-[var(--color-primary-light)] mb-5">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[var(--color-text)] mb-2">
          {t.whatWeDo.pillars[1].title}
        </h3>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
          {t.whatWeDo.pillars[1].desc}
        </p>
      </div>

      <!-- Pillar 3: Trusted Partnerships -->
      <div class="flex flex-col items-start">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-[var(--color-primary-light)] mb-5">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            <path d="m9 12 2 2 4-4" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[var(--color-text)] mb-2">
          {t.whatWeDo.pillars[2].title}
        </h3>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
          {t.whatWeDo.pillars[2].desc}
        </p>
      </div>
    </div>

    <!-- Explore Services Link -->
    <div class="mt-12">
      <a
        href="#services"
        class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-primary)] hover:text-[var(--color-primary-hover)] transition-colors duration-200"
      >
        {t.whatWeDo.linkText}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>
