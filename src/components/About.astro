---
interface Props {
  locale?: 'en' | 'zh';
}

const { locale = 'en' } = Astro.props;

import { siteContent } from '../content/en';
import { siteContent as zhContent } from '../content/zh';
const t = locale === 'zh' ? zhContent : siteContent;

import { Image } from 'astro:assets';
import cedarTree from '../assets/cedar-tree.png';
---

<section id="about" class="bg-[var(--color-surface)] py-20 lg:py-28 border-b border-[var(--color-border)]">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text Content -->
      <div>
        <p class="text-sm font-medium text-[var(--color-primary)] tracking-wide uppercase">
          {t.about.label}
        </p>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold text-[var(--color-text)] leading-tight">
          {t.about.title}
        </h2>
        <p class="mt-4 text-base text-[var(--color-text-secondary)] leading-relaxed max-w-md">
          {t.about.desc}
        </p>
        <a
          href="#"
          class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-[var(--color-primary)] hover:text-[var(--color-primary-hover)] transition-colors duration-200"
        >
          {t.about.linkText}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      <!-- Cedar Tree Image -->
      <div class="relative">
        <Image
          src={cedarTree}
          alt="A tall cedar tree standing on a misty mountainside"
          class="w-full h-auto rounded-2xl"
          format="webp"
          quality={85}
        />
      </div>
    </div>
  </div>
</section>
