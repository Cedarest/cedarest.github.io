---
interface Props {
  locale?: 'en' | 'zh';
}

const { locale = 'en' } = Astro.props;

import { siteContent } from '../content/en';
import { siteContent as zhContent } from '../content/zh';
const t = locale === 'zh' ? zhContent : siteContent;

import { Image } from 'astro:assets';
import logoDarkText from '../assets/cedarest-logo-horizontal.png';
import logoWhiteText from '../assets/cedarest-logo-horizontal-white.png';

const navLinks = [
  { key: 'home' as const, href: locale === 'zh' ? '/zh/' : '/' },
  { key: 'about' as const, href: '#about' },
  { key: 'services' as const, href: '#services' },
  { key: 'contact' as const, href: '#contact' },
];
---

<header class="sticky top-0 z-50 border-b" style="background: var(--header-bg); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%); border-color: var(--header-border); box-shadow: 0 1px 0 var(--header-shadow-inset) inset, 0 1px 3px var(--header-shadow);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center h-16">
      <!-- Logo -->
      <a href={locale === 'zh' ? '/zh/' : '/'} class="flex items-center shrink-0 mr-3">
        <!-- Light Mode Logo (Dark Text) -->
        <Image
          src={logoDarkText}
          alt="Cedarest"
          class="logo-light h-[38.4px] w-auto"
          format="webp"
          quality={90}
        />
        <!-- Dark Mode Logo (White Text) -->
        <Image
          src={logoWhiteText}
          alt="Cedarest"
          class="logo-dark h-[38.4px] w-auto"
          format="webp"
          quality={90}
        />
      </a>

      <!-- Spacer: pushes nav + actions to the right -->
      <div class="flex-1"></div>

      <!-- Right: Nav + Language + CTA -->
      <div class="flex items-center gap-6">
        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-6">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm font-medium text-[var(--header-text)] hover:text-[var(--color-primary)] transition-colors duration-200"
            >
              {t.nav[link.key]}
            </a>
          ))}
        </nav>

        <!-- Language Switcher -->
        <a
          href={locale === 'zh' ? '/' : '/zh/'}
          class="text-sm font-medium text-[var(--header-text)] hover:text-[var(--color-primary)] transition-colors duration-200"
        >
          {locale === 'zh' ? 'EN' : '中文'}
        </a>

        <!-- CTA Button -->
        <a
          href="#contact"
          class="hidden sm:inline-flex items-center px-5 py-2 bg-[var(--color-primary)] text-white text-sm font-medium rounded-full hover:bg-[var(--color-primary-hover)] transition-colors duration-200"
        >
          {t.nav.letsTalk}
        </a>

        <!-- Theme Toggle Button -->
        <button
          id="theme-toggle"
          class="flex items-center justify-center w-8 h-8 text-[var(--color-text)] cursor-pointer transition-colors duration-200"
          aria-label="Toggle dark mode"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg class="w-4 h-4 hidden dark-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z"></path>
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg class="w-4 h-4 light-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
        </button>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden flex items-center justify-center w-8 h-8 cursor-pointer relative"
          aria-label="Toggle menu"
        >
          <span class="absolute w-6 h-[1.5px] bg-[var(--color-text)] transition-all duration-300 -translate-y-1.5"></span>
          <span class="absolute w-6 h-[1.5px] bg-[var(--color-text)] transition-all duration-300"></span>
          <span class="absolute w-6 h-[1.5px] bg-[var(--color-text)] transition-all duration-300 opacity-0"></span>
          <span class="absolute w-6 h-[1.5px] bg-[var(--color-text)] transition-all duration-300 translate-y-1.5"></span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<div id="mobile-menu" class="md:hidden fixed inset-0 top-16 z-40 translate-x-full transition-transform duration-300 ease-in-out border-t border-[var(--color-border)]" style="background: var(--mobile-menu-bg, rgba(255, 255, 255, 0.95)); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%);">
  <nav class="flex flex-col items-center gap-6 pt-12">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="mobile-menu-link text-lg font-medium text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors duration-200"
      >
        {t.nav[link.key]}
      </a>
    ))}
    <a
      href="#contact"
      class="mobile-menu-link mt-4 inline-flex items-center px-8 py-3 bg-[var(--color-primary)] text-white font-medium rounded-full hover:bg-[var(--color-primary-hover)] transition-colors duration-200"
    >
      {t.nav.letsTalk}
    </a>
  </nav>
</div>

<script>
  // Mobile Menu Logic
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const bars = btn?.querySelectorAll('span');

  function toggleMenu(forceClose = false) {
    if (!menu || !bars || bars.length !== 4) return;
    
    const isCurrentlyClosed = menu.classList.contains('translate-x-full');
    
    if (forceClose || !isCurrentlyClosed) {
      // Close menu (Return to hamburger)
      menu.classList.add('translate-x-full');
      btn?.classList.remove('menu-open');
      bars[0].classList.remove('translate-y-0', 'rotate-45');
      bars[0].classList.add('-translate-y-1.5');
      
      bars[1].classList.remove('rotate-90');
      
      bars[2].classList.remove('opacity-100');
      bars[2].classList.add('opacity-0');
      
      bars[3].classList.remove('translate-y-0', '-rotate-45');
      bars[3].classList.add('translate-y-1.5');
    } else {
      // Open menu (Transform into "米" asterisk)
      menu.classList.remove('translate-x-full');
      btn?.classList.add('menu-open');
      
      // Diagonal 1 (Top bar)
      bars[0].classList.remove('-translate-y-1.5');
      bars[0].classList.add('translate-y-0', 'rotate-45');
      
      // Vertical (Middle bar 1)
      bars[1].classList.add('rotate-90');
      
      // Horizontal (Middle bar 2 - fades in)
      bars[2].classList.remove('opacity-0');
      bars[2].classList.add('opacity-100');
      
      // Diagonal 2 (Bottom bar)
      bars[3].classList.remove('translate-y-1.5');
      bars[3].classList.add('translate-y-0', '-rotate-45');
    }
  }

  btn?.addEventListener('click', () => toggleMenu());

  // Close menu when a link is clicked
  const links = menu?.querySelectorAll('.mobile-menu-link');
  links?.forEach(link => {
    link.addEventListener('click', () => {
      toggleMenu(true);
    });
  });

  // Dark Mode Toggle Logic
  const themeToggleBtn = document.getElementById('theme-toggle');
  const sunIcon = themeToggleBtn?.querySelector('.dark-icon');
  const moonIcon = themeToggleBtn?.querySelector('.light-icon');

  // Detect and apply theme
  function getThemePreference() {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme');
    }
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  const currentTheme = getThemePreference();
  const root = document.documentElement;

  function updateThemeUI(theme: string) {
    if (theme === 'dark') {
      root.classList.add('dark');
      root.classList.remove('light');
      sunIcon?.classList.remove('hidden');
      moonIcon?.classList.add('hidden');
    } else {
      root.classList.remove('dark');
      root.classList.add('light');
      sunIcon?.classList.add('hidden');
      moonIcon?.classList.remove('hidden');
    }
  }

  // Initialize theme
  updateThemeUI(currentTheme);

  themeToggleBtn?.addEventListener('click', () => {
    const isDark = root.classList.contains('dark');
    const newTheme = isDark ? 'light' : 'dark';
    localStorage.setItem('theme', newTheme);
    updateThemeUI(newTheme);
  });
</script>

<style>
  /* Handle manual toggle logic */
  :global(html.dark) .logo-light {
    display: none !important;
  }
  :global(html.light) .logo-dark {
    display: none !important;
  }

  /* Handle fallback system preference logic before any manual button clicks */
  @media (prefers-color-scheme: dark) {
    :global(html:not(.light)) .logo-light {
      display: none !important;
    }
  }
  @media (prefers-color-scheme: light) {
    :global(html:not(.dark)) .logo-dark {
      display: none !important;
    }
  }
</style>
