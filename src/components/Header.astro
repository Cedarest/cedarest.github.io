---
interface Props {
  locale?: 'en' | 'zh';
}

const { locale = 'en' } = Astro.props;

import { siteContent } from '../content/en';
import { siteContent as zhContent } from '../content/zh';
const t = locale === 'zh' ? zhContent : siteContent;

import { Image } from 'astro:assets';
import logoImg from '../assets/cedarest-logo-horizontal-white.png';

const navLinks = [
  { key: 'home' as const, href: locale === 'zh' ? '/zh/' : '/' },
  { key: 'about' as const, href: '#about' },
  { key: 'services' as const, href: '#services' },
  { key: 'work' as const, href: '#work' },
  { key: 'contact' as const, href: '#contact' },
];
---

<header class="sticky top-0 z-50 border-b" style="background: var(--header-bg); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%); border-color: var(--header-border); box-shadow: 0 1px 0 var(--header-shadow-inset) inset, 0 1px 3px var(--header-shadow);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center h-16">
      <!-- Logo -->
      <a href={locale === 'zh' ? '/zh/' : '/'} class="flex items-center shrink-0 mr-3">
        <Image
          src={logoImg}
          alt="Cedarest"
          class="h-[38.4px] w-auto"
          format="webp"
          quality={90}
        />
      </a>

      <!-- Spacer: pushes nav + actions to the right -->
      <div class="flex-1"></div>

      <!-- Right: Nav + Language + CTA -->
      <div class="flex items-center gap-6">
        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-6">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm font-medium text-[var(--header-text)] hover:text-[var(--color-primary)] transition-colors duration-200"
            >
              {t.nav[link.key]}
            </a>
          ))}
        </nav>

        <!-- Language Switcher -->
        <a
          href={locale === 'zh' ? '/' : '/zh/'}
          class="text-sm font-medium text-[var(--header-text)] hover:text-[var(--color-primary)] transition-colors duration-200"
        >
          {locale === 'zh' ? 'EN' : '中文'}
        </a>

        <!-- CTA Button -->
        <a
          href="#contact"
          class="hidden sm:inline-flex items-center px-5 py-2 bg-[var(--color-primary)] text-white text-sm font-medium rounded-full hover:bg-[var(--color-primary-hover)] transition-colors duration-200"
        >
          {t.nav.letsTalk}
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden flex flex-col gap-1.5 cursor-pointer p-2"
          aria-label="Toggle menu"
        >
          <span class="block w-6 h-0.5 bg-[var(--color-text)] transition-transform duration-300"></span>
          <span class="block w-6 h-0.5 bg-[var(--color-text)] transition-opacity duration-300"></span>
          <span class="block w-6 h-0.5 bg-[var(--color-text)] transition-transform duration-300"></span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<div id="mobile-menu" class="md:hidden fixed inset-0 top-16 z-40 translate-x-full transition-transform duration-300 ease-in-out" style="background: rgba(10, 10, 10, 0.85); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%);">
  <nav class="flex flex-col items-center gap-6 pt-12">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="text-lg font-medium text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors duration-200"
      >
        {t.nav[link.key]}
      </a>
    ))}
    <a
      href="#contact"
      class="mt-4 inline-flex items-center px-8 py-3 bg-[var(--color-primary)] text-white font-medium rounded-full hover:bg-[var(--color-primary-hover)] transition-colors duration-200"
    >
      {t.nav.letsTalk}
    </a>
  </nav>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const bars = btn?.querySelectorAll('span');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('translate-x-0');
    // Animate hamburger to X
    if (bars && bars.length === 3) {
      if (isOpen) {
        bars[0].classList.add('translate-y-2', 'rotate-45');
        bars[1].classList.add('opacity-0');
        bars[2].classList.add('-translate-y-2', '-rotate-45');
      } else {
        bars[0].classList.remove('translate-y-2', 'rotate-45');
        bars[1].classList.remove('opacity-0');
        bars[2].classList.remove('-translate-y-2', '-rotate-45');
      }
    }
  });
</script>
