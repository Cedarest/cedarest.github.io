---
interface Props {
  locale?: 'en' | 'zh';
}

const { locale = 'en' } = Astro.props;

import { siteContent } from '../content/en';
import { siteContent as zhContent } from '../content/zh';
const t = locale === 'zh' ? zhContent : siteContent;
---

<section id="services" class="bg-[var(--color-bg)] py-20 lg:py-28 border-b border-[var(--color-border)]">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mb-12">
      <p class="text-sm font-medium text-[var(--color-primary)] tracking-wide uppercase">
        {t.services.label}
      </p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-[var(--color-text)] leading-tight">
        {t.services.title}
      </h2>
    </div>

    <!-- Service Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Card 1: Consulting -->
      <div class="group p-6 lg:p-8 bg-[var(--color-surface)] rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-lg transition-all duration-300">
        <div class="mb-5">
          <!-- Leaf icon -->
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10Z" />
            <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[var(--color-text)] mb-2">
          {t.services.items[0].title}
        </h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
          {t.services.items[0].desc}
        </p>
        <svg width="20" height="20" viewBox="0 0 16 16" fill="none" class="text-[var(--color-primary)] group-hover:translate-x-1 transition-transform duration-200" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>

      <!-- Card 2: Development -->
      <div class="group p-6 lg:p-8 bg-[var(--color-surface)] rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-lg transition-all duration-300">
        <div class="mb-5">
          <!-- Stacked layers icon -->
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z" />
            <path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65" />
            <path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[var(--color-text)] mb-2">
          {t.services.items[1].title}
        </h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
          {t.services.items[1].desc}
        </p>
        <svg width="20" height="20" viewBox="0 0 16 16" fill="none" class="text-[var(--color-primary)] group-hover:translate-x-1 transition-transform duration-200" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>

      <!-- Card 3: Growth -->
      <div class="group p-6 lg:p-8 bg-[var(--color-surface)] rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:shadow-lg transition-all duration-300">
        <div class="mb-5">
          <!-- Bar chart icon -->
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="20" x2="18" y2="10" />
            <line x1="12" y1="20" x2="12" y2="4" />
            <line x1="6" y1="20" x2="6" y2="14" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[var(--color-text)] mb-2">
          {t.services.items[2].title}
        </h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-6">
          {t.services.items[2].desc}
        </p>
        <svg width="20" height="20" viewBox="0 0 16 16" fill="none" class="text-[var(--color-primary)] group-hover:translate-x-1 transition-transform duration-200" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
    </div>
  </div>
</section>
